{
  "$schema": "https://getfresh.dev/schema/configuration.schema.json",
  "editor": {
    "line_numbers": true,
    "tab_size": 2
  },
  "file_explorer": {
    "show_hidden": true
  },
  "languages": {
    "astro": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "bash": {
      "tab_size": 2
    },
    "css": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "go": {
      "formatter": {
        "command": "gofmt"
      },
      "tab_size": 2
    },
    "html": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "java": {
      "formatter": {
        "command": "google-java-format"
      },
      "tab_size": 2
    },
    "javascript": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "json": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "lua": {
      "tab_size": 2
    },
    "markdown": {
      "tab_size": 2
    },
    "python": {
      "formatter": {
        "command": "ruff",
        "args": [
          "format",
          "-"
        ]
      },
      "tab_size": 2
    },
    "rust": {
      "formatter": {
        "command": "rustfmt"
      },
      "tab_size": 2
    },
    "svelte": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "toml": {
      "tab_size": 2
    },
    "tsx": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "typescript": {
      "formatter": {
        "command": "prettier",
        "args": [
          "--write"
        ]
      },
      "tab_size": 2
    },
    "yaml": {
      "tab_size": 2
    }
  },
  "lsp": {
    "astro": {
      "command": "/home/giks/.volta/bin/astro-ls",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "bash": {
      "command": "/home/giks/.volta/bin/bash-language-server",
      "args": [
        "start"
      ],
      "enabled": true,
      "auto_start": false
    },
    "css": {
      "command": "/home/giks/.volta/bin/vscode-css-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "go": {
      "command": "/home/giks/go/bin/gopls",
      "enabled": true,
      "initialization_options": {
        "gopls": {
          "gofumpt": true,
          "staticcheck": true
        }
      },
      "auto_start": false
    },
    "html": {
      "command": "/home/giks/.volta/bin/vscode-html-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "java": {
      "command": "jdtls",
      "enabled": false,
      "auto_start": false
    },
    "javascript": {
      "command": "/home/giks/.volta/bin/typescript-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "json": {
      "command": "/home/giks/.volta/bin/vscode-json-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "latex": {
      "command": "texlab",
      "enabled": true,
      "auto_start": false
    },
    "lua": {
      "command": "lua-language-server",
      "enabled": true,
      "auto_start": false
    },
    "markdown": {
      "command": "marksman",
      "enabled": true,
      "auto_start": false
    },
    "python": {
      "command": "/home/giks/.volta/bin/pyright-langserver",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "initialization_options": {
        "python": {
          "analysis": {
            "autoSearchPaths": true,
            "typeCheckingMode": "basic",
            "useLibraryCodeForTypes": true
          }
        }
      },
      "auto_start": false
    },
    "rust": {
      "command": "/home/giks/.cargo/bin/rust-analyzer",
      "enabled": true,
      "initialization_options": {
        "rust-analyzer": {
          "cargo": {
            "allFeatures": true
          },
          "check": {
            "command": "clippy"
          }
        }
      },
      "auto_start": false
    },
    "svelte": {
      "command": "/home/giks/.volta/bin/svelteserver",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "tailwindcss": {
      "command": "/home/giks/.volta/bin/tailwindcss-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "toml": {
      "command": "taplo",
      "args": [
        "lsp",
        "stdio"
      ],
      "enabled": true,
      "auto_start": false
    },
    "typescript": {
      "command": "/home/giks/.volta/bin/typescript-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "initialization_options": {
        "preferences": {
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayParameterNameHints": "all",
          "includeInlayVariableTypeHints": true
        }
      },
      "auto_start": false
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": [
        "--stdio"
      ],
      "enabled": true,
      "auto_start": false
    }
  }
}
