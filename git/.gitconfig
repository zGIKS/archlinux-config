[user]
	name = zGIKS
	email = mateo@giks.net
	signingkey = /home/giks/.ssh/id_ed25519.pub

[init]
	defaultBranch = main

[pull]
	rebase = true

[core]
	editor = fresh
	excludesfile = /home/giks/.gitignore_global

[commit]
	gpgsign = true

[url "ssh://git@github.com/"]
	insteadOf = https://github.com/

[gpg]
	format = ssh

[credential "https://dev.azure.com"]
	useHttpPath = true

[credential]
	helper = store
